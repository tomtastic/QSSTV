---
# Clang-Format configuration for QSSTV
# Using Google C++ Style Guide

Language: Cpp
BasedOnStyle: Google

# Indentation (keep existing 2-space indent)
IndentWidth: 2
TabWidth: 2
UseTab: Never
ColumnLimit: 120

# Includes - preserve order to avoid breaking dependencies
SortIncludes: Never
IncludeBlocks: Preserve

# Pointers and references - keep left alignment
DerivePointerAlignment: false
PointerAlignment: Left

# Other customizations
MaxEmptyLinesToKeep: 2
