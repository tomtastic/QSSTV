---
# Clang-Tidy configuration for QSSTV
# This file defines which checks to run during development and CI

Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-reserved-identifier,
  cert-*,
  -cert-err58-cpp,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  google-readability-casting,
  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -modernize-macro-to-enum,
  performance-*,
  -performance-enum-size,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity,
  -readability-uppercase-literal-suffix

# Treat these as errors (blocking issues)
WarningsAsErrors: >
  bugprone-use-after-move,
  bugprone-dangling-handle,
  cert-err34-c,
  modernize-use-nullptr

# Header filter - ONLY check our own code in src/
# This excludes Qt, system headers, and third-party libraries
HeaderFilterRegex: '^.*/(src|include)/.*\.(h|hpp)$'

# System headers to ignore (suppress warnings from these paths)
SystemHeaders: false

# Format style
FormatStyle: file

CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.ParameterCase
    value: camelBack
