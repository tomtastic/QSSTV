#!/bin/bash
# Pre-commit hook for QSSTV
# Runs clang-tidy on staged C++ files

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Check if compile_commands.json exists
if [ ! -f "build/compile_commands.json" ]; then
    echo -e "${RED}Error: build/compile_commands.json not found${NC}"
    echo "Please run: cd build && cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON .."
    exit 1
fi

# Get list of staged C++ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|cc|cxx|c\+\+|h|hpp)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No C++ files to check${NC}"
    exit 0
fi

# Check if clang-tidy is available
if ! command -v clang-tidy &> /dev/null; then
    echo -e "${RED}Error: clang-tidy not found${NC}"
    echo "Please install clang-tidy to enable pre-commit checks"
    exit 1
fi

# Run clang-tidy on each staged file
ERRORS=0
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        echo "Checking $FILE..."
        
        # Run clang-tidy and capture critical errors only
        OUTPUT=$(clang-tidy "$FILE" -p build --system-headers=false \
                 --warnings-as-errors='bugprone-use-after-move,bugprone-dangling-handle,cert-err34-c,modernize-use-nullptr' \
                 2>&1 || true)
        
        # Filter out system headers and third-party libraries
        FILTERED=$(echo "$OUTPUT" | grep -v "/usr/local/" | \
                                    grep -v "/usr/include/" | \
                                    grep -v "/Library/Frameworks/" | \
                                    grep -v "Qt[A-Z]" | \
                                    grep -v "warning:.*generated" || true)
        
        # Check for actual errors (not just warnings) in our code
        if echo "$FILTERED" | grep -q "error:"; then
            echo "$FILTERED"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

if [ $ERRORS -ne 0 ]; then
    echo -e "${RED}Clang-tidy found $ERRORS critical error(s)${NC}"
    echo -e "${YELLOW}Fix the errors or use 'git commit --no-verify' to skip checks${NC}"
    exit 1
fi

echo -e "${GREEN}All checks passed!${NC}"
exit 0
